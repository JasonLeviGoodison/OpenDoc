{
  "name": "opendoc",
  "version": "0.1.0",
  "description": "Open-source secure document sharing, viewer analytics, and virtual data rooms.",
  "license": "AGPL-3.0-only",
  "private": true,
  "homepage": "https://github.com/JasonLeviGoodison/OpenDoc",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/JasonLeviGoodison/OpenDoc.git"
  },
  "bugs": {
    "url": "https://github.com/JasonLeviGoodison/OpenDoc/issues"
  },
  "keywords": [
    "opendoc",
    "nextjs",
    "documents",
    "analytics",
    "data-room",
    "agpl"
  ],
  "scripts": {
    "dev": "next dev",
    "build": "node --import tsx scripts/run-build-migrations.ts && next build",
    "start": "next start",
    "lint": "eslint",
    "test": "node --import tsx --test tests/*.test.ts",
    "previews:backfill": "node --import tsx scripts/backfill-document-previews.ts",
    "db:baseline": "node --import tsx scripts/baseline-initial-migration.ts",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:migrate:deploy": "node --import tsx scripts/run-build-migrations.ts",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio"
  },
  "dependencies": {
    "@clerk/nextjs": "^7.0.12",
    "@clerk/themes": "^2.4.57",
    "@radix-ui/react-avatar": "^1.1.11",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-progress": "^1.1.8",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@supabase/supabase-js": "^2.103.0",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "drizzle-orm": "^0.45.2",
    "framer-motion": "^12.38.0",
    "lucide-react": "^1.8.0",
    "nanoid": "^5.1.7",
    "next": "16.2.3",
    "pdfjs-dist": "^5.6.205",
    "postgres": "^3.4.9",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-dropzone": "^15.0.0",
    "react-pdf": "^10.4.1",
    "recharts": "^3.8.1",
    "resend": "^6.11.0",
    "tailwind-merge": "^3.5.0",
    "uuid": "^13.0.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/pg": "^8.20.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "drizzle-kit": "^0.31.10",
    "eslint": "^9",
    "eslint-config-next": "16.2.3",
    "tailwindcss": "^4",
    "tsx": "^4.21.0",
    "typescript": "^5"
  }
}
