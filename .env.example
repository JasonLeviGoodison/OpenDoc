# App
OPENDOC_TOKEN_SECRET=replace-with-a-long-random-secret
# Optional local LibreOffice binary path used when DOCUMENT_CONVERTER_URL is not set.
OPENDOC_SOFFICE_PATH=
# Remote document converter (Gotenberg on Render) for Office-to-PDF conversion in production.
# Deploy the service from services/document-converter/ — see its README for setup instructions.
# URL of your Render Gotenberg service, e.g. https://opendoc-document-converter.onrender.com
DOCUMENT_CONVERTER_URL=
# Must match GOTENBERG_API_BASIC_AUTH_USERNAME set on the Render service.
DOCUMENT_CONVERTER_USERNAME=
# Must match GOTENBERG_API_BASIC_AUTH_PASSWORD set on the Render service.
DOCUMENT_CONVERTER_PASSWORD=

# Database
DATABASE_URL=postgres://postgres:postgres@localhost:5432/opendoc
MIGRATION_DATABASE_URL=postgres://postgres:postgres@localhost:5432/opendoc

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key
NEXT_PUBLIC_MAX_UPLOAD_FILE_SIZE_BYTES=52428800

# Clerk
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_replace_me
CLERK_SECRET_KEY=sk_test_replace_me
CLERK_WEBHOOK_SIGNING_SECRET=whsec_replace_me

# Stripe
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_ID_MONTHLY=
STRIPE_PRICE_ID_LIFETIME=
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Email
RESEND_API_KEY=re_replace_me
